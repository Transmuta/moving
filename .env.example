# Modelo dos segredos locais. Copie para `.env` e preencha (o `.env` é gitignored).
# Credenciais do Google Cloud Console → APIs & Services → Credentials → OAuth client ID.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# BASE do redirect. O AshAuthentication anexa "/user/google/callback"; então a URI a
# cadastrar no console (Authorized redirect URI) é <base>/user/google/callback.
# Fluxo BFF (ADR-005): a URI é a do WEB, que proxia o callback para a API.
#   base cadastrada → http://localhost:5173/auth/user/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5173/auth
